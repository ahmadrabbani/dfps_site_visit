# Copy to keystore.properties in this folder (android/) and fill in.
# Paths are relative to the android/ directory.
#
# Generate a keystore once:
#   keytool -genkeypair -v -storetype PKCS12 -keystore keystores/upload.p12 -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=keystores/upload.p12
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
