# Copy to `.env` in the project root (see react-native-config).
# Android: rebuild native app after changing values.
#
# Full base URL to the PHP front controller (no trailing slash), e.g.
#   API_BASE_URL=http://103.8.115.199:91/dfps-site/public/index.php
# Required in real-API mode (USE_FAKE_API=false).
API_BASE_URL=

# Housing portal login (POST username + password). Matches housingportal/login.php.
# Test:  http://103.8.115.199:91/housingSurveyCommercial/login.php
# Prod:  https://lda.gop.pk/housingSurveyCommercial/login.php
LOGIN_URL=

# Violation types (cc_violation_list.php, no query string).
# Example: http://103.8.115.199:91/test/survey/cc/cc_violation_list.php
VIOLATION_LIST_URL=

# Site visit upload (forward_cc_survey.php).
# Example: http://103.8.115.199:91/test/survey/cc/forward_cc_survey.php
CC_SURVEY_URL=

# CC application list for case picker (cc_application_list.php).
# Example: http://103.8.115.199:91/test/survey/cc/cc_application_list.php
CC_APPLICATION_LIST_URL=

# Optional: hourly survey API key secret (defaults to housing portal value).
CC_SURVEY_API_SECRET=

# __DEV__ only: offline fallback for BYPASS_LOGIN_USERNAME when portal is unreachable.
# Release builds always use portal login for every officer account.
BYPASS_LOGIN=false
BYPASS_LOGIN_USERNAME=junaid.tp3

# Set to true in __DEV__ only to skip all API calls and use mock login/penalties/upload.
# Omit or set to false to use the real API (requires valid API_BASE_URL or default).
USE_FAKE_API=false

# Optional: Sentry error reporting (leave empty to disable). Rebuild native after change.
SENTRY_DSN=
