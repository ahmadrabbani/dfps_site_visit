# Copy to `.env` in the project root (see react-native-config).
# Android: rebuild native app after changing values.
#
# Full base URL to the PHP front controller (no trailing slash), e.g.
#   API_BASE_URL=http://103.8.115.199:91/dfps-site/public/index.php
# If unset, the app uses the built-in legacy default URL.
API_BASE_URL=

# Set to true in __DEV__ only to skip all API calls and use mock login/penalties/upload.
# Omit or set to false to use the real API (requires valid API_BASE_URL or default).
USE_FAKE_API=false
